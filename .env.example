# LedgerFlow 环境变量配置
# 复制此文件为 .env 并填入实际值

# Django
SECRET_KEY=change-me-to-a-random-string
DEBUG=False
ALLOWED_HOSTS=your-domain.com,your-ip
CSRF_TRUSTED_ORIGINS=http://your-domain.com,http://your-ip

# Database (Docker 部署无需修改)
DB_PATH=/app/db/db.sqlite3

# AI Advisor (可选)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
